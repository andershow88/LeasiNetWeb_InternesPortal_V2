<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – LeasiNetWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="lnw-body">

@if (User.Identity?.IsAuthenticated == true)
{
    <nav class="navbar navbar-expand-lg lnw-navbar">
        <div class="container-fluid">
            <a class="navbar-brand lnw-brand" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-building"></i> LeasiNetWeb
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-file-earmark-text"></i> Anträge
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Antraege" asp-action="Index">Alle Anträge</a></li>
                            <li><a class="dropdown-item" asp-controller="Antraege" asp-action="MeinePruefungen">Meine Prüfungen</a></li>
                            <li><a class="dropdown-item" asp-controller="Antraege" asp-action="MeineGenehmigungen">Meine Genehmigungen</a></li>
                            <li><a class="dropdown-item" asp-controller="Antraege" asp-action="MeineZweiteVoten">2. Vote</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Antraege" asp-action="Archiv">Archiv</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Nachrichten" asp-action="Index">
                            <i class="bi bi-envelope"></i> Nachrichten
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Hilfe" asp-action="Index">
                            <i class="bi bi-question-circle"></i> Hilfe
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text text-muted small">@User.FindFirst("Rolle")?.Value</span>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right"></i> Abmelden
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
}

<div class="container-fluid lnw-content">
    @if (TempData["Erfolg"] is string erfolg)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-check-circle"></i> @erfolg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Fehler"] is string fehler)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @fehler
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <main role="main" class="pb-4">
        @RenderBody()
    </main>
</div>

<footer class="lnw-footer">
    <div class="container-fluid">
        <span class="text-muted small">&copy; @DateTime.Now.Year LeasiNetWeb &mdash; Internes Portal</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
