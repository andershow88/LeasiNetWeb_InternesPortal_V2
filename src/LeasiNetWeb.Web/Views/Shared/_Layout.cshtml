<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – LeasiNetWeb</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
</head>
<body class="mc-body">

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
    <aside class="mc-sidebar" id="mcSidebar">
        <!-- Brand / Logo -->
        <div class="mc-sidebar-brand">
            <a asp-controller="Dashboard" asp-action="Index" class="mc-logo" style="text-decoration:none">
                <img src="~/merkur-logo.svg" alt="Merkur Privatbank" class="mc-logo-img" />
                <div class="mc-logo-title">LeasiNetWeb</div>
                <div class="mc-logo-subtitle">Internes Portal</div>
            </a>
        </div>

        <!-- Angemeldeter Benutzer -->
        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als</div>
            <div class="mc-sidebar-bank-name">@User.Identity.Name</div>
            <div class="mc-sidebar-bank-user">@(User.FindFirst("Rolle")?.Value ?? "–")</div>
        </div>

        <!-- Navigation -->
        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a asp-controller="Dashboard" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Antraege" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Antraege" ? "active" : "")">
                    <i class="bi bi-file-earmark-text"></i> Alle Anträge
                </a>
            </li>
            @if (User.HasClaim("Rolle", "SachbearbeiterMB") || User.HasClaim("Rolle", "Administrator"))
            {
                <li class="mc-nav-item">
                    <a asp-controller="Antraege" asp-action="MeinePruefungen" class="mc-nav-link">
                        <i class="bi bi-clipboard-check"></i> Meine Prüfungen
                    </a>
                </li>
            }
            @if (User.HasClaim("Rolle", "InternerPruefer") || User.HasClaim("Rolle", "Administrator"))
            {
                <li class="mc-nav-item">
                    <a asp-controller="InternePruefung" asp-action="Index"
                       class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "InternePruefung" ? "active" : "")">
                        <i class="bi bi-shield-check"></i> Interne Kontrollen
                    </a>
                </li>
            }
            @if (User.HasClaim("Rolle", "Genehmiger") || User.HasClaim("Rolle", "Administrator"))
            {
                <li class="mc-nav-item">
                    <a asp-controller="Antraege" asp-action="MeineGenehmigungen" class="mc-nav-link">
                        <i class="bi bi-check2-square"></i> Genehmigungen
                    </a>
                </li>
                <li class="mc-nav-item">
                    <a asp-controller="Antraege" asp-action="MeineZweiteVoten" class="mc-nav-link">
                        <i class="bi bi-person-check"></i> 2. Vote
                    </a>
                </li>
            }
            <li class="mc-nav-item">
                <a asp-controller="Vertraege" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vertraege" ? "active" : "")">
                    <i class="bi bi-file-earmark-ruled"></i> Verträge
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Antraege" asp-action="Archiv" class="mc-nav-link">
                    <i class="bi bi-archive"></i> Archiv
                </a>
            </li>
            @if (User.HasClaim("Rolle", "Administrator"))
            {
                <li class="mc-nav-item" style="margin-top:0.5rem; border-top:1px solid var(--mc-border); padding-top:0.5rem;">
                    <a asp-controller="Admin" asp-action="Index"
                       class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-shield-lock"></i> Administration
                    </a>
                </li>
            }
            <li class="mc-nav-item" style="@(User.HasClaim("Rolle", "Administrator") ? "" : "margin-top:0.5rem; border-top:1px solid var(--mc-border); padding-top:0.5rem;")">
                <a asp-controller="Nachrichten" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Nachrichten" ? "active" : "")">
                    <i class="bi bi-envelope"></i> Nachrichten
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Auswertung" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auswertung" ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i> Auswertung
                </a>
            </li>
            <li class="mc-nav-item">
                <a asp-controller="Hilfe" asp-action="Index"
                   class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hilfe" ? "active" : "")">
                    <i class="bi bi-question-circle"></i> Hilfe
                </a>
            </li>
        </ul>

        <!-- Sidebar Footer: Logout -->
        <div class="mc-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-right"></i> Abmelden
                </button>
            </form>
        </div>
    </aside>

    <!-- ── Main ─────────────────────────────────────────────────────────── -->
    <div class="mc-main">
        <!-- Top Bar -->
        <header class="mc-topbar">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle" aria-label="Menü öffnen">
                <i class="bi bi-list"></i>
            </button>
            <div class="mc-breadcrumb">
                @if (ViewData["BreadcrumbParent"] is string parent && ViewData["BreadcrumbParentUrl"] is string parentUrl)
                {
                    <a href="@parentUrl">@parent</a>
                    <span class="separator">/</span>
                }
                <span>@ViewData["Title"]</span>
            </div>
            <div class="mc-topbar-right">
                <!-- KI-Assistent Button -->
                <button id="aiBtn" onclick="aiOeffnen()" title="KI-Assistent (Strg+K)"
                        style="background:none; border:none; cursor:pointer; display:flex; align-items:center; gap:0.4rem; padding:0.3rem 0.7rem; border-radius:20px; border:1px solid var(--mc-border); color:var(--mc-text-muted); font-size:0.8rem; transition:all .2s;">
                    <i class="bi bi-stars" style="font-size:1rem; color:var(--mc-gold);"></i>
                    <span class="d-none d-sm-inline">KI-Assistent</span>
                    <span class="d-none d-md-inline" style="font-size:0.7rem; opacity:.6; background:var(--mc-surface); border-radius:4px; padding:0 4px;">⌘K</span>
                </button>
                <button class="mc-theme-toggle" id="themeToggle" title="Dark Mode umschalten">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
                <span class="d-none d-md-inline">@User.Identity.Name</span>
            </div>
        </header>

        <!-- ── KI-Assistent Modal ──────────────────────────────────────── -->
        <div id="aiModal" style="display:none; position:fixed; inset:0; z-index:1000; align-items:center; justify-content:center;">
            <!-- Backdrop -->
            <div onclick="aiSchliessen()" style="position:absolute; inset:0; background:rgba(0,0,0,0.55); backdrop-filter:blur(4px);"></div>
            <!-- Dialog -->
            <div style="position:relative; width:min(700px,96vw); height:min(600px,90vh); background:var(--mc-surface); border-radius:16px; box-shadow:0 25px 60px rgba(0,0,0,0.35); display:flex; flex-direction:column; overflow:hidden; border:1px solid var(--mc-border);">

                <!-- Header -->
                <div style="padding:1rem 1.2rem; background:linear-gradient(135deg,#16213e 0%,#1a2a50 100%); display:flex; align-items:center; gap:0.7rem; flex-shrink:0;">
                    <i class="bi bi-stars" style="font-size:1.3rem; color:#c9a84c;"></i>
                    <div style="flex:1;">
                        <div style="font-weight:700; color:#fff; font-size:.95rem;">LeasiNet KI-Assistent</div>
                        <div style="font-size:.72rem; color:rgba(255,255,255,.55);">Fragen zur Software, Workflows und Antragsdaten</div>
                    </div>
                    <button onclick="aiSchliessen()" style="background:none; border:none; color:rgba(255,255,255,.6); cursor:pointer; font-size:1.3rem; padding:0; line-height:1;">&times;</button>
                </div>

                <!-- Verlauf -->
                <div id="aiVerlauf" style="flex:1; overflow-y:auto; padding:1rem 1.2rem; display:flex; flex-direction:column; gap:0.8rem;">
                    <!-- Begrüßung -->
                    <div class="ai-msg ai-msg-assistant">
                        <div class="ai-msg-bubble">
                            Hallo! Ich bin dein KI-Assistent für LeasiNet.<br>
                            Frag mich zu <strong>Workflows</strong>, <strong>Rollen</strong>, <strong>Antragsstatus</strong> oder such nach konkreten Anträgen.<br><br>
                            <em>Beispiele:</em>
                            <ul style="margin:.4rem 0 0 1rem; font-size:.85rem;">
                                <li>Zeig mir alle offenen Anträge</li>
                                <li>Wie funktioniert die interne Kontrolle?</li>
                                <li>Was bedeutet Status "BeiZweitemGenehmiger"?</li>
                                <li>Wann brauche ich eine zweite Vote?</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Eingabe -->
                <div style="padding:.85rem 1.2rem; border-top:1px solid var(--mc-border); background:var(--mc-surface); flex-shrink:0;">
                    <div style="display:flex; gap:.6rem; align-items:flex-end;">
                        <textarea id="aiEingabe" rows="2" placeholder="Frage stellen… (Enter = senden, Shift+Enter = Zeilenumbruch)"
                                  style="flex:1; resize:none; border:1px solid var(--mc-border); border-radius:10px; padding:.6rem .9rem; font-size:.88rem; background:var(--mc-bg); color:var(--mc-text); outline:none; line-height:1.4; font-family:inherit; transition:border-color .2s;"
                                  onfocus="this.style.borderColor='var(--mc-primary)'"
                                  onblur="this.style.borderColor='var(--mc-border)'"
                                  onkeydown="aiKeydown(event)"></textarea>
                        <button id="aiSendenBtn" onclick="aiSenden()"
                                style="background:linear-gradient(135deg,#16213e,#1a3a6e); color:#fff; border:none; border-radius:10px; padding:.55rem 1.1rem; cursor:pointer; font-size:.85rem; font-weight:600; display:flex; align-items:center; gap:.4rem; white-space:nowrap; transition:opacity .2s;">
                            <i class="bi bi-send-fill"></i> Senden
                        </button>
                    </div>
                    <div style="font-size:.72rem; color:var(--mc-text-muted); margin-top:.4rem;">
                        Powered by Claude AI &mdash; Antragsdaten werden automatisch einbezogen
                    </div>
                </div>
            </div>
        </div>

        <!-- Flash Messages -->
        <div class="mc-content" style="padding-bottom:0; padding-top:0.75rem; min-height:0; flex:none;">
            @if (TempData["Erfolg"] is string erfolg)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @erfolg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Fehler"] is string fehler)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @fehler
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <!-- Page Content -->
        <main class="mc-content" role="main">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA &mdash; LeasiNetWeb Internes Portal</span>
        </footer>
    </div>

    <!-- Mobile sidebar overlay -->
    <div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:199;" onclick="closeSidebar()"></div>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    // ── Dark Mode ────────────────────────────────────────────────────────────
    (function () {
        const stored = localStorage.getItem('mc-theme') || 'light';
        document.documentElement.setAttribute('data-theme', stored);
        updateThemeIcon(stored);
    })();

    document.getElementById('themeToggle')?.addEventListener('click', function () {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateThemeIcon(next);
    });

    function updateThemeIcon(theme) {
        const icon = document.getElementById('themeIcon');
        if (!icon) return;
        icon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }

    // ── Mobile Sidebar ───────────────────────────────────────────────────────
    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        const sidebar = document.getElementById('mcSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        sidebar.classList.toggle('open');
        overlay.style.display = sidebar.classList.contains('open') ? 'block' : 'none';
    });

    function closeSidebar() {
        document.getElementById('mcSidebar')?.classList.remove('open');
        document.getElementById('sidebarOverlay').style.display = 'none';
    }
</script>

@await RenderSectionAsync("Scripts", required: false)

<style>
    /* ── KI-Assistent Nachrichten ─────────────────────────────────────── */
    .ai-msg { display:flex; }
    .ai-msg-user { justify-content:flex-end; }
    .ai-msg-assistant { justify-content:flex-start; }
    .ai-msg-bubble {
        max-width:85%;
        padding:.6rem .95rem;
        border-radius:14px;
        font-size:.88rem;
        line-height:1.55;
        word-break:break-word;
    }
    .ai-msg-user .ai-msg-bubble {
        background:linear-gradient(135deg,#16213e,#1a3a6e);
        color:#fff;
        border-bottom-right-radius:4px;
    }
    .ai-msg-assistant .ai-msg-bubble {
        background:var(--mc-bg);
        border:1px solid var(--mc-border);
        color:var(--mc-text);
        border-bottom-left-radius:4px;
    }
    .ai-msg-bubble p { margin:.4rem 0 0; }
    .ai-msg-bubble p:first-child { margin-top:0; }
    .ai-msg-bubble ul,
    .ai-msg-bubble ol { margin:.4rem 0 0 1.1rem; }
    .ai-msg-bubble code {
        background:rgba(0,0,0,.08);
        padding:.1em .35em;
        border-radius:4px;
        font-size:.85em;
        font-family:monospace;
    }
    .ai-msg-bubble strong { font-weight:700; }
    .ai-msg-bubble em { font-style:italic; opacity:.85; }
    .ai-typing {
        display:flex;
        align-items:center;
        gap:.3rem;
        padding:.5rem .9rem;
        background:var(--mc-bg);
        border:1px solid var(--mc-border);
        border-radius:14px;
        border-bottom-left-radius:4px;
        font-size:.82rem;
        color:var(--mc-text-muted);
    }
    .ai-typing-dot {
        width:7px; height:7px;
        border-radius:50%;
        background:var(--mc-gold);
        animation:aiDot 1.2s infinite ease-in-out;
    }
    .ai-typing-dot:nth-child(2) { animation-delay:.2s; }
    .ai-typing-dot:nth-child(3) { animation-delay:.4s; }
    @@keyframes aiDot {
        0%,80%,100% { transform:scale(0.6); opacity:.5; }
        40% { transform:scale(1.1); opacity:1; }
    }
</style>

<script>
    // ── KI-Assistent ──────────────────────────────────────────────────────────
    let aiVerlauf = [];

    function aiOeffnen() {
        document.getElementById('aiModal').style.display = 'flex';
        setTimeout(() => document.getElementById('aiEingabe')?.focus(), 50);
    }

    function aiSchliessen() {
        document.getElementById('aiModal').style.display = 'none';
    }

    // Strg+K / ⌘+K öffnet den Assistenten
    document.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            const modal = document.getElementById('aiModal');
            if (modal.style.display === 'none') aiOeffnen();
            else aiSchliessen();
        }
        if (e.key === 'Escape') aiSchliessen();
    });

    function aiKeydown(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            aiSenden();
        }
    }

    function aiMarkdown(text) {
        // Einfaches Markdown → HTML (bold, italic, code, ul, Absätze)
        return text
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/`(.+?)`/g, '<code>$1</code>')
            .replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>')
            .replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>')
            .replace(/(<li>[\s\S]+?<\/li>)/g, '<ul>$1</ul>')
            .replace(/<\/ul>\s*<ul>/g, '')
            .replace(/\n\n+/g, '</p><p>')
            .replace(/\n/g, '<br>')
            .replace(/^(.+)$/, '<p>$1</p>');
    }

    function aiNachrichtAppend(rolle, html) {
        const verlauf = document.getElementById('aiVerlauf');
        const div = document.createElement('div');
        div.className = `ai-msg ai-msg-${rolle}`;
        div.innerHTML = `<div class="ai-msg-bubble">${html}</div>`;
        verlauf.appendChild(div);
        verlauf.scrollTop = verlauf.scrollHeight;
        return div;
    }

    async function aiSenden() {
        const eingabe = document.getElementById('aiEingabe');
        const frage = eingabe.value.trim();
        if (!frage) return;

        eingabe.value = '';
        eingabe.style.height = 'auto';

        // User-Nachricht anzeigen
        aiNachrichtAppend('user', aiMarkdown(frage));

        // Tipp-Indikator
        const typing = document.createElement('div');
        typing.className = 'ai-msg ai-msg-assistant';
        typing.innerHTML = '<div class="ai-typing"><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><span>KI denkt nach…</span></div>';
        const verlauf = document.getElementById('aiVerlauf');
        verlauf.appendChild(typing);
        verlauf.scrollTop = verlauf.scrollHeight;

        const btn = document.getElementById('aiSendenBtn');
        btn.disabled = true;
        btn.style.opacity = '0.5';

        try {
            const res = await fetch('/AiAssistent/Fragen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ frage, verlauf: aiVerlauf })
            });
            const data = await res.json();

            verlauf.removeChild(typing);

            if (data.error) {
                aiNachrichtAppend('assistant', `<span style="color:#e74c3c;"><i class="bi bi-exclamation-triangle"></i> ${data.error}</span>`);
            } else {
                // Verlauf für Kontext speichern
                aiVerlauf.push({ rolle: 'user', text: frage });
                aiVerlauf.push({ rolle: 'assistant', text: data.antwort });
                // Nur letzte 10 Nachrichten (5 Runden) behalten
                if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
                aiNachrichtAppend('assistant', aiMarkdown(data.antwort));
            }
        } catch {
            verlauf.removeChild(typing);
            aiNachrichtAppend('assistant', '<span style="color:#e74c3c;">Verbindungsfehler. Bitte versuche es erneut.</span>');
        } finally {
            btn.disabled = false;
            btn.style.opacity = '1';
            eingabe.focus();
        }
    }
</script>
</body>
</html>
