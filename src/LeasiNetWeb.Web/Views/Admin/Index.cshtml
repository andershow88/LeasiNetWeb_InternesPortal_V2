@{
    ViewData["Title"] = "Administration";
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-shield-lock me-2"></i>Administration</h1>
        <p class="mc-page-subtitle">Systemverwaltung und Konfiguration</p>
    </div>
</div>

<div class="mc-kpi-grid" style="grid-template-columns: repeat(auto-fill, minmax(180px,1fr));">
    <a asp-action="Benutzer" class="mc-kpi-card text-decoration-none">
        <div class="mc-kpi-icon blue"><i class="bi bi-people"></i></div>
        <div class="mc-kpi-label">Benutzer gesamt</div>
        <div class="mc-kpi-value">@ViewBag.AnzahlBenutzer</div>
        <div class="mc-kpi-sub">@ViewBag.AnzahlAktiveBenutzer aktiv</div>
    </a>
    <a asp-action="Leasinggesellschaften" class="mc-kpi-card text-decoration-none">
        <div class="mc-kpi-icon green"><i class="bi bi-bank"></i></div>
        <div class="mc-kpi-label">Leasinggesellschaften</div>
        <div class="mc-kpi-value">@ViewBag.AnzahlLG</div>
        <div class="mc-kpi-sub">@ViewBag.AnzahlAktiveLG aktiv</div>
    </a>
    <a asp-action="Stammdaten" class="mc-kpi-card text-decoration-none">
        <div class="mc-kpi-icon gold"><i class="bi bi-table"></i></div>
        <div class="mc-kpi-label">Stammdaten</div>
        <div class="mc-kpi-value"><i class="bi bi-pencil-square" style="font-size:1.3rem;"></i></div>
        <div class="mc-kpi-sub">Ablehngründe, Gerätetypen</div>
    </a>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-4">
        <div class="mc-card">
            <div class="mc-card-header"><h2 class="mc-card-title"><i class="bi bi-people"></i> Benutzerverwaltung</h2></div>
            <div class="mc-card-body">
                <p style="color:var(--mc-text-muted); font-size:0.85rem;">Benutzerkonten anlegen, Rollen zuweisen, aktivieren oder deaktivieren.</p>
                <a asp-action="Benutzer" class="btn-mc-primary"><i class="bi bi-arrow-right"></i> Öffnen</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mc-card">
            <div class="mc-card-header"><h2 class="mc-card-title"><i class="bi bi-bank"></i> Leasinggesellschaften</h2></div>
            <div class="mc-card-body">
                <p style="color:var(--mc-text-muted); font-size:0.85rem;">Partner-Leasinggesellschaften verwalten, Obligo-Limits festlegen.</p>
                <a asp-action="Leasinggesellschaften" class="btn-mc-primary"><i class="bi bi-arrow-right"></i> Öffnen</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mc-card">
            <div class="mc-card-header"><h2 class="mc-card-title"><i class="bi bi-table"></i> Stammdaten</h2></div>
            <div class="mc-card-body">
                <p style="color:var(--mc-text-muted); font-size:0.85rem;">Ablehnungsgründe und Gerätetypen konfigurieren.</p>
                <a asp-action="Stammdaten" class="btn-mc-primary"><i class="bi bi-arrow-right"></i> Öffnen</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mc-card" style="border-color: var(--mc-warning, #e6a817);">
            <div class="mc-card-header"><h2 class="mc-card-title"><i class="bi bi-database-fill-gear"></i> Demo-Daten</h2></div>
            <div class="mc-card-body">
                <p style="color:var(--mc-text-muted); font-size:0.85rem;">
                    Alle bestehenden Anträge und Verträge löschen und 100 Demo-Einträge mit realistischen Testdaten neu anlegen.
                </p>
                <button type="button" class="btn-mc-secondary" style="color:#c8860a;"
                        data-bs-toggle="modal" data-bs-target="#demoDatenModal">
                    <i class="bi bi-arrow-repeat"></i> Demo-Daten laden
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Demo-Daten Bestätigungsdialog -->
<div class="modal fade" id="demoDatenModal" tabindex="-1" aria-labelledby="demoDatenModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="background:var(--mc-surface); color:var(--mc-text);">
            <div class="modal-header" style="border-bottom:1px solid var(--mc-border);">
                <h5 class="modal-title" id="demoDatenModalLabel">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Demo-Daten laden
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
                <p><strong>Achtung:</strong> Dieser Vorgang löscht alle vorhandenen Leasinganträge und Verträge unwiderruflich und ersetzt sie durch 100 Demo-Datensätze.</p>
                <p style="color:var(--mc-text-muted); font-size:0.85rem;">Benutzer, Leasinggesellschaften und Stammdaten bleiben erhalten.</p>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--mc-border);">
                <button type="button" class="btn-mc-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <form asp-action="DemoDatenLaden" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-mc-primary" style="background:#c8860a; border-color:#c8860a;">
                        <i class="bi bi-arrow-repeat"></i> Ja, Demo-Daten laden
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
