@model IEnumerable<LeasiNetWeb.Application.DTOs.BenutzerListeDto>
@{
    ViewData["Title"] = "Benutzerverwaltung";
}

<div class="mc-page-header">
    <div>
        <div style="font-size:0.82rem; color:var(--mc-text-muted); margin-bottom:0.4rem;">
            <a asp-action="Index" style="color:var(--mc-primary);">Administration</a>
            <span style="margin:0 0.4rem;">/</span><span>Benutzer</span>
        </div>
        <h1 class="mc-page-title"><i class="bi bi-people me-2"></i>Benutzerverwaltung</h1>
    </div>
    <a asp-action="BenutzerNeu" class="btn-mc-primary">
        <i class="bi bi-person-plus"></i> Neuer Benutzer
    </a>
</div>

<div class="mc-card">
    <div style="padding:0;">
        <div class="mc-table-wrapper">
            <table class="mc-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Benutzername</th>
                        <th>E-Mail</th>
                        <th>Rolle</th>
                        <th>Leasinggesellschaft</th>
                        <th>Status</th>
                        <th>Erstellt</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@b.Anzeigename</td>
                            <td><code>@b.Benutzername</code></td>
                            <td style="font-size:0.83rem;">@b.EMail</td>
                            <td><span class="mc-badge badge-primary">@b.Rolle</span></td>
                            <td style="color:var(--mc-text-muted); font-size:0.83rem;">@(b.Leasinggesellschaft ?? "–")</td>
                            <td>
                                @if (b.IstAktiv)
                                {
                                    <span class="mc-badge badge-success">Aktiv</span>
                                }
                                else
                                {
                                    <span class="mc-badge badge-secondary">Inaktiv</span>
                                }
                            </td>
                            <td style="color:var(--mc-text-muted); font-size:0.82rem;">@b.ErstelltAm.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="BenutzerBearbeiten" asp-route-id="@b.Id"
                                       class="btn-mc-ghost" style="font-size:0.78rem; padding:0.3rem 0.6rem;"
                                       title="Bearbeiten">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (b.IstAktiv)
                                    {
                                        <form asp-action="BenutzerDeaktivieren" asp-route-id="@b.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-mc-ghost" style="font-size:0.78rem; padding:0.3rem 0.6rem; color:#b05050;"
                                                    title="Deaktivieren"
                                                    onclick="return confirm('Benutzer @b.Benutzername deaktivieren?')">
                                                <i class="bi bi-person-x"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="BenutzerAktivieren" asp-route-id="@b.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-mc-ghost" style="font-size:0.78rem; padding:0.3rem 0.6rem; color:#4a7c59;"
                                                    title="Aktivieren">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
