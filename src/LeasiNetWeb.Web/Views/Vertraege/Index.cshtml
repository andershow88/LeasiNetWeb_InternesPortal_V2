@using LeasiNetWeb.Application.DTOs
@using LeasiNetWeb.Domain.Enums
@model IEnumerable<VertragListeDto>
@{
    ViewData["Title"] = "Verträge";
    var aktuellerStatus = ViewBag.AktuellerStatus as VertragStatus?;
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-file-earmark-ruled me-2"></i>Verträge</h1>
    </div>
</div>

<!-- Filter -->
<div class="mc-filter-bar mb-3">
    @foreach (var s in Enum.GetValues<VertragStatus>())
    {
        <a asp-action="Index" asp-route-status="@((int)s)"
           class="mc-filter-btn @(aktuellerStatus == s ? "active" : "")">
            @StatusLabel(s)
        </a>
    }
    <a asp-action="Index" class="mc-filter-btn @(aktuellerStatus == null ? "active" : "")">Alle</a>
</div>

<div class="mc-card">
    <div style="padding:0;">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:var(--mc-text-muted);">
                <i class="bi bi-file-earmark-ruled" style="font-size:2.5rem; opacity:0.3;"></i>
                <p class="mt-3 mb-0">Keine Verträge vorhanden.</p>
            </div>
        }
        else
        {
            <table class="mc-table">
                <thead>
                    <tr>
                        <th>Vertrag-Nr.</th>
                        <th>Antrag-Nr.</th>
                        <th>Leasinggesellschaft</th>
                        <th>Typ</th>
                        <th>Finanzierungsbetrag</th>
                        <th>Laufzeit</th>
                        <th>Beginn</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td><code>@v.VertragNummer</code></td>
                            <td>
                                <a asp-controller="Antraege" asp-action="Details" asp-route-id="@v.LeasingantragId"
                                   style="color:var(--mc-primary);">@v.AntragNummer</a>
                            </td>
                            <td style="color:var(--mc-text-muted); font-size:0.85rem;">@(v.Leasinggesellschaft ?? "–")</td>
                            <td style="font-size:0.85rem;">@(v.Vertragstyp ?? "–")</td>
                            <td class="fw-semibold">@v.Finanzierungsbetrag.ToString("N2") €</td>
                            <td style="color:var(--mc-text-muted); font-size:0.85rem;">
                                @(v.LaufzeitMonate.HasValue ? $"{v.LaufzeitMonate} Monate" : "–")
                            </td>
                            <td style="color:var(--mc-text-muted); font-size:0.85rem;">
                                @(v.Vertragsbeginn.HasValue ? v.Vertragsbeginn.Value.ToString("dd.MM.yyyy") : "–")
                            </td>
                            <td><span class="mc-badge @StatusBadgeClass(v.Status)">@StatusLabel(v.Status)</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@v.Id"
                                   class="btn-mc-ghost" style="font-size:0.8rem; padding:0.25rem 0.6rem;">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@functions {
    private static string StatusBadgeClass(VertragStatus s) => s switch {
        VertragStatus.InVorbereitung => "badge-secondary",
        VertragStatus.Aktiv         => "badge-success",
        VertragStatus.Beendet       => "badge-primary",
        VertragStatus.Gekuendigt    => "badge-danger",
        VertragStatus.Archiviert    => "badge-secondary",
        _                           => "badge-secondary"
    };

    private static string StatusLabel(VertragStatus s) => s switch {
        VertragStatus.InVorbereitung => "In Vorbereitung",
        VertragStatus.Aktiv         => "Aktiv",
        VertragStatus.Beendet       => "Beendet",
        VertragStatus.Gekuendigt    => "Gekündigt",
        VertragStatus.Archiviert    => "Archiviert",
        _                           => s.ToString()
    };
}
