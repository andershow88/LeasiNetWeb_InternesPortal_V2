@model IEnumerable<LeasiNetWeb.Application.DTOs.NachrichtDto>
@{
    ViewData["Title"] = "Nachrichten";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-envelope me-2"></i>Posteingang</h1>
    <a asp-action="Neu" class="btn btn-primary">
        <i class="bi bi-pencil-square me-1"></i> Neue Nachricht
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-envelope-open fs-2"></i>
                <p class="mt-2">Keine Nachrichten vorhanden.</p>
            </div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var n in Model)
                {
                    <li class="list-group-item list-group-item-action @(!n.Gelesen ? "fw-semibold" : "")">
                        <a asp-action="Details" asp-route-id="@n.Id" class="text-decoration-none text-dark d-flex justify-content-between align-items-center">
                            <div>
                                @if (!n.Gelesen)
                                {
                                    <span class="badge bg-primary me-2">Neu</span>
                                }
                                <span>@n.Betreff</span>
                                <span class="text-muted fw-normal ms-2 small">von @n.Absender</span>
                                @if (n.AntragNummer is not null)
                                {
                                    <span class="badge bg-light text-dark border ms-2 small">@n.AntragNummer</span>
                                }
                            </div>
                            <span class="text-muted small">@n.ErstelltAm.ToString("dd.MM.yyyy HH:mm")</span>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</div>
