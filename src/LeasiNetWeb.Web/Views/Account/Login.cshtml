@model LeasiNetWeb.Web.ViewModels.LoginViewModel
@using LeasiNetWeb.Web.ViewModels
@{
    Layout = null;
    ViewData["Title"] = "Anmelden";
}
<!DOCTYPE html>
<html lang="de" data-theme="light" id="loginHtml">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LeasiNetWeb – Anmelden</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" />
</head>
<body class="mc-login-body">

<div class="mc-login-wrapper">
    <div class="mc-login-card">

        <!-- Logo -->
        <div class="mc-login-logo">
            <img src="~/merkur-logo.svg" alt="Merkur Privatbank" class="mc-login-logo-img" />
            <div class="mc-login-title">LeasiNetWeb</div>
            <div class="mc-login-subtitle">Internes Leasing-Portal</div>
        </div>

        <hr class="mc-login-divider" />

        <!-- Formular -->
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            @if (!ViewContext.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <span asp-validation-summary="All"></span>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Benutzername" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Benutzername" class="form-control" placeholder="Benutzername"
                           autofocus autocomplete="username" />
                </div>
                <span asp-validation-for="Benutzername" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Passwort" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Passwort" class="form-control" placeholder="Passwort"
                           autocomplete="current-password" />
                </div>
                <span asp-validation-for="Passwort" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="MerkenAuf" class="form-check-input" />
                <label asp-for="MerkenAuf" class="form-check-label small"></label>
            </div>

            <button type="submit" class="mc-login-btn">
                <i class="bi bi-box-arrow-in-right me-1"></i> Anmelden
            </button>
        </form>

        <!-- Demo-Zugänge -->
        <div class="mc-login-demo-box mt-3">
            <div class="mc-login-demo-box-header">
                <i class="bi bi-person-badge"></i> Demo-Zugänge – Klick zum Übernehmen
            </div>
            <div class="mc-login-demo-grid">
                <div class="mc-login-demo-entry" onclick="demoLogin('admin','Admin1234!')" style="cursor:pointer;" title="Klicken zum Anmelden">
                    <div class="mc-login-demo-role">Administrator</div>
                    <div class="mc-login-demo-creds">
                        <span>admin</span>
                        <span>Admin1234!</span>
                    </div>
                </div>
                <div class="mc-login-demo-entry" onclick="demoLogin('sachbearbeiter.mb','Demo1234!')" style="cursor:pointer;" title="Klicken zum Anmelden">
                    <div class="mc-login-demo-role">Sachbearbeiter MB</div>
                    <div class="mc-login-demo-creds">
                        <span>sachbearbeiter.mb</span>
                        <span>Demo1234!</span>
                    </div>
                </div>
                <div class="mc-login-demo-entry" onclick="demoLogin('genehmiger.mb','Demo1234!')" style="cursor:pointer;" title="Klicken zum Anmelden">
                    <div class="mc-login-demo-role">Genehmiger</div>
                    <div class="mc-login-demo-creds">
                        <span>genehmiger.mb</span>
                        <span>Demo1234!</span>
                    </div>
                </div>
                <div class="mc-login-demo-entry" onclick="demoLogin('sachbearbeiter.lg','Demo1234!')" style="cursor:pointer;" title="Klicken zum Anmelden">
                    <div class="mc-login-demo-role">Sachbearbeiter LG</div>
                    <div class="mc-login-demo-creds">
                        <span>sachbearbeiter.lg</span>
                        <span>Demo1234!</span>
                    </div>
                </div>
                <div class="mc-login-demo-entry" onclick="demoLogin('pruefer.mb','Demo1234!')" style="cursor:pointer;" title="Klicken zum Anmelden">
                    <div class="mc-login-demo-role">Interner Prüfer</div>
                    <div class="mc-login-demo-creds">
                        <span>pruefer.mb</span>
                        <span>Demo1234!</span>
                    </div>
                </div>
                <div class="mc-login-demo-entry" style="display:flex; align-items:center; justify-content:center; color:var(--mc-text-muted); font-size:0.72rem; text-align:center; padding:.7rem 1rem;">
                    <div><i class="bi bi-cursor" style="font-size:1.1rem; display:block; margin-bottom:.25rem; opacity:.4;"></i>Eintrag anklicken<br>zum Übernehmen</div>
                </div>
            </div>
        </div>

        <button type="button"
                onclick="window.open('/Account/Dokumentation','_blank')"
                class="mc-login-btn mt-3"
                style="background:transparent; border:1.5px solid #c8a96e; color:#c8a96e; display:flex; align-items:center; justify-content:center; gap:0.5rem;">
            <i class="bi bi-file-earmark-pdf"></i>Anwenderdokumentation Herunterladen
        </button>
    </div>
</div>

<!-- Dark-Mode-Toggle (oben rechts) -->
<button id="loginThemeToggle" onclick="loginThemeToggle()" title="Dark Mode umschalten"
        style="position:fixed; top:1rem; right:1rem; background:var(--mc-surface);
               border:1px solid var(--mc-border); border-radius:50%; width:38px; height:38px;
               display:flex; align-items:center; justify-content:center;
               cursor:pointer; color:var(--mc-text-muted); font-size:1rem;
               box-shadow:0 2px 8px rgba(0,0,0,.12); transition:all .2s; z-index:100;">
    <i class="bi bi-moon-stars-fill" id="loginThemeIcon"></i>
</button>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script>
    (function () {
        const stored = localStorage.getItem('mc-theme') || 'light';
        document.getElementById('loginHtml').setAttribute('data-theme', stored);
        updateLoginIcon(stored);
    })();

    function loginThemeToggle() {
        const html = document.getElementById('loginHtml');
        const current = html.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateLoginIcon(next);
    }

    function updateLoginIcon(theme) {
        const icon = document.getElementById('loginThemeIcon');
        if (icon) icon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }

    function demoLogin(user, pass) {
        document.getElementById('Benutzername').value = user;
        document.getElementById('Passwort').value = pass;
        document.querySelector('form').submit();
    }
</script>
</body>
</html>
