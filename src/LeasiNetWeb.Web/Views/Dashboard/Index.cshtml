@using LeasiNetWeb.Domain.Enums
@model LeasiNetWeb.Application.DTOs.DashboardDto
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
        <p class="mc-page-subtitle">Übersicht Ihrer Leasinganträge und Kennzahlen</p>
    </div>
    <a asp-controller="Antraege" asp-action="Neu" class="btn-mc-primary">
        <i class="bi bi-plus-circle"></i> Neuer Antrag
    </a>
</div>

<!-- Handlungsbedarf -->
@if (Model.ZuPruefendeAntraege > 0 || Model.ZuGenehmigendeAntraege > 0 || Model.PendingZweiteVoten > 0 || Model.UngeleseneNachrichten > 0)
{
    <div class="alert alert-warning d-flex flex-wrap gap-2 align-items-center mb-4 py-2" style="border-radius:var(--mc-radius);">
        <strong class="me-1"><i class="bi bi-bell-fill me-1"></i>Handlungsbedarf:</strong>
        @if (Model.ZuPruefendeAntraege > 0)
        {
            <a asp-controller="Antraege" asp-action="MeinePruefungen"
               class="mc-badge badge-warning text-decoration-none">
                <i class="bi bi-clipboard-check"></i> @Model.ZuPruefendeAntraege zu prüfen
            </a>
        }
        @if (Model.ZuGenehmigendeAntraege > 0)
        {
            <a asp-controller="Antraege" asp-action="MeineGenehmigungen"
               class="mc-badge badge-danger text-decoration-none">
                <i class="bi bi-check2-square"></i> @Model.ZuGenehmigendeAntraege zu genehmigen
            </a>
        }
        @if (Model.PendingZweiteVoten > 0)
        {
            <a asp-controller="Antraege" asp-action="MeineZweiteVoten"
               class="mc-badge badge-primary text-decoration-none">
                <i class="bi bi-person-check"></i> @Model.PendingZweiteVoten 2. Vote ausstehend
            </a>
        }
        @if (Model.UngeleseneNachrichten > 0)
        {
            <a asp-controller="Nachrichten" asp-action="Index"
               class="mc-badge badge-secondary text-decoration-none">
                <i class="bi bi-envelope"></i> @Model.UngeleseneNachrichten ungelesene Nachrichten
            </a>
        }
    </div>
}

<!-- KPI Grid -->
<div class="mc-kpi-grid">
    <div class="mc-kpi-card">
        <div class="mc-kpi-icon gold"><i class="bi bi-inbox"></i></div>
        <div class="mc-kpi-label">Offene Anträge</div>
        <div class="mc-kpi-value">@Model.OffeneAntraege</div>
        <div class="mc-kpi-sub">Warten auf Bearbeitung</div>
    </div>
    <div class="mc-kpi-card">
        <div class="mc-kpi-icon blue"><i class="bi bi-arrow-repeat"></i></div>
        <div class="mc-kpi-label">In Bearbeitung</div>
        <div class="mc-kpi-value">@Model.AntraegeInBearbeitung</div>
        <div class="mc-kpi-sub">Aktive Vorgänge</div>
    </div>
    <div class="mc-kpi-card">
        <div class="mc-kpi-icon green"><i class="bi bi-check2-circle"></i></div>
        <div class="mc-kpi-label">Aktive Verträge</div>
        <div class="mc-kpi-value">@Model.AktiveVertraege</div>
        <div class="mc-kpi-sub">Laufende Leasingverträge</div>
    </div>
    <div class="mc-kpi-card">
        <div class="mc-kpi-icon navy"><i class="bi bi-currency-euro"></i></div>
        <div class="mc-kpi-label">Obligo gesamt</div>
        <div class="mc-kpi-value text-currency">@Model.GesamtObligoAktiv.ToString("N0") €</div>
        <div class="mc-kpi-sub">Aktives Gesamtvolumen</div>
    </div>
</div>

<!-- Aktuelle Anträge -->
<div class="mc-card">
    <div class="mc-card-header">
        <h2 class="mc-card-title"><i class="bi bi-clock-history"></i> Meine aktuellen Anträge</h2>
        <a asp-controller="Antraege" asp-action="Index" class="btn-mc-ghost">
            <i class="bi bi-arrow-right"></i> Alle anzeigen
        </a>
    </div>
    <div class="mc-card-body" style="padding:0;">
        @if (!Model.MeineAktuellenAntraege.Any())
        {
            <div class="text-center py-5" style="color:var(--mc-text-muted);">
                <i class="bi bi-inbox" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0 small">Keine aktuellen Anträge vorhanden.</p>
            </div>
        }
        else
        {
            <div class="mc-table-wrapper">
                <table class="mc-table">
                    <thead>
                        <tr>
                            <th>Antrag-Nr.</th>
                            <th>Typ</th>
                            <th>Status</th>
                            <th>Leasinggesellschaft</th>
                            <th style="text-align:right;">Obligo</th>
                            <th>Geändert</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var antrag in Model.MeineAktuellenAntraege)
                        {
                            <tr>
                                <td><code>@antrag.AntragNummer</code></td>
                                <td>@antrag.AntragTyp</td>
                                <td><span class="mc-badge @StatusBadgeClass(antrag.Status)">@antrag.Status</span></td>
                                <td>@(antrag.Leasinggesellschaft ?? "–")</td>
                                <td style="text-align:right;" class="text-currency">@antrag.Obligo.ToString("N2") €</td>
                                <td style="color:var(--mc-text-muted); font-size:0.82rem;">@antrag.GeaendertAm.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <a asp-controller="Antraege" asp-action="Details" asp-route-id="@antrag.Id"
                                       class="btn-mc-ghost" style="font-size:0.78rem; padding:0.3rem 0.7rem;">
                                        Details <i class="bi bi-chevron-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string StatusBadgeClass(AntragStatus status) => status switch
    {
        AntragStatus.Entwurf                  => "badge-secondary",
        AntragStatus.Eingereicht              => "badge-warning",
        AntragStatus.InPruefung               => "badge-primary",
        AntragStatus.BeiMitarbeiter           => "badge-primary",
        AntragStatus.BeiLeasinggesellschaft   => "badge-primary",
        AntragStatus.ZweiteVoteErforderlich   => "badge-warning",
        AntragStatus.Genehmigt                => "badge-success",
        AntragStatus.Abgelehnt                => "badge-danger",
        AntragStatus.Archiviert               => "badge-secondary",
        _                                     => "badge-secondary"
    };
}
