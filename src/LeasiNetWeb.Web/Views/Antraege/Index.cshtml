@using LeasiNetWeb.Domain.Enums
@model IEnumerable<LeasiNetWeb.Application.DTOs.AntragListeDto>
@{
    ViewData["Title"] = "Leasinganträge";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-file-earmark-text me-2"></i>Leasinganträge</h1>
    <a asp-action="Neu" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Neuer Antrag
    </a>
</div>

<!-- Status-Filter -->
<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.AktuellerStatus == null ? "btn-primary" : "btn-outline-secondary")">Alle</a>
    @foreach (AntragStatus s in Enum.GetValues<AntragStatus>())
    {
        <a asp-action="Index" asp-route-status="@((int)s)"
           class="btn btn-sm @(ViewBag.AktuellerStatus?.ToString() == s.ToString() ? "btn-primary" : "btn-outline-secondary")">
            @s
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-2"></i>
                <p class="mt-2">Keine Anträge gefunden.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Antrag-Nr.</th>
                            <th>Typ</th>
                            <th>Status</th>
                            <th>Eingereicht von</th>
                            <th>Leasinggesellschaft</th>
                            <th>Sachbearbeiter</th>
                            <th class="text-end">Obligo</th>
                            <th>Erstellt</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>
                                    <code>@a.AntragNummer</code>
                                    @if (a.ZweiteVoteErforderlich)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">2. Vote</span>
                                    }
                                </td>
                                <td>@a.AntragTyp</td>
                                <td><span class="badge @StatusBadgeClass(a.Status)">@a.Status</span></td>
                                <td>@a.EingereichtVon</td>
                                <td>@(a.Leasinggesellschaft ?? "–")</td>
                                <td>@(a.SachbearbeiterMB ?? "–")</td>
                                <td class="text-end">@a.Obligo.ToString("N2") €</td>
                                <td class="text-muted small">@a.ErstelltAm.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string StatusBadgeClass(AntragStatus status) => status switch
    {
        AntragStatus.Entwurf => "bg-secondary",
        AntragStatus.Eingereicht => "bg-warning text-dark",
        AntragStatus.InPruefung => "bg-info text-dark",
        AntragStatus.BeiMitarbeiter => "bg-primary",
        AntragStatus.BeiLeasinggesellschaft => "bg-info",
        AntragStatus.ZweiteVoteErforderlich => "bg-warning text-dark",
        AntragStatus.Genehmigt => "bg-success",
        AntragStatus.Abgelehnt => "bg-danger",
        AntragStatus.Archiviert => "bg-light text-dark",
        _ => "bg-secondary"
    };
}
