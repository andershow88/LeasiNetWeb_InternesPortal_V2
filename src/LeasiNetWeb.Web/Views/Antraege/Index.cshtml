@using LeasiNetWeb.Domain.Enums
@model IEnumerable<LeasiNetWeb.Application.DTOs.AntragListeDto>
@{
    var seitenTitel      = ViewBag.SeitenTitel      as string ?? "Leasinganträge";
    var seitenUntertitel = ViewBag.SeitenUntertitel as string ?? "Alle Anträge im Überblick";
    var seitenIcon       = ViewBag.SeitenIcon       as string ?? "bi-file-earmark-text";
    ViewData["Title"] = seitenTitel;
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi @seitenIcon me-2"></i>@seitenTitel</h1>
        <p class="mc-page-subtitle">@seitenUntertitel</p>
    </div>
    @if (ViewBag.SeitenTitel == null)
    {
        <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            <a asp-action="Neu" class="btn-mc-primary">
                <i class="bi bi-plus-circle"></i> Neuer Antrag
            </a>
            <button type="button" class="btn-mc-ghost"
                    style="border-color:var(--mc-gold); color:var(--mc-gold);"
                    onclick="kiUploadModal.show()">
                <i class="bi bi-stars"></i> Neuer Antrag mit KI
            </button>
        </div>
    }
</div>

<!-- Status-Filter -->
<div class="mc-filter-bar">
    <a asp-action="Index"
       class="@(ViewBag.AktuellerStatus == null ? "btn-mc-primary" : "btn-mc-ghost") btn-mc-ghost"
       style="@(ViewBag.AktuellerStatus == null ? "background:var(--mc-primary);color:#fff;" : "")">
        Alle
    </a>
    @foreach (AntragStatus s in Enum.GetValues<AntragStatus>())
    {
        <a asp-action="Index" asp-route-status="@((int)s)"
           class="btn-mc-ghost"
           style="@(ViewBag.AktuellerStatus?.ToString() == s.ToString() ? "background:var(--mc-primary);color:#fff;" : "")">
            @s
        </a>
    }
</div>

<div class="mc-card">
    <div style="padding:0;">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:var(--mc-text-muted);">
                <i class="bi bi-inbox" style="font-size:2rem;"></i>
                <p class="mt-2 mb-0 small">Keine Anträge gefunden.</p>
            </div>
        }
        else
        {
            <div class="mc-table-wrapper">
                <table class="mc-table">
                    <thead>
                        <tr>
                            <th>Antrag-Nr.</th>
                            <th>Typ</th>
                            <th>Status</th>
                            <th>Eingereicht von</th>
                            <th>Leasinggesellschaft</th>
                            <th>Sachbearbeiter</th>
                            <th style="text-align:right;">Obligo</th>
                            <th>Erstellt</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>
                                    <code>@a.AntragNummer</code>
                                    @if (a.ZweiteVoteErforderlich)
                                    {
                                        <span class="mc-badge badge-warning ms-1">2. Vote</span>
                                    }
                                    @if (a.KiErstellt)
                                    {
                                        <span class="mc-badge ms-1" style="background:#2a2010; color:#d4a04a; border:1px solid #6b4a00;"
                                              title="Dieser Antrag wurde mit KI-Unterstützung erstellt">
                                            <i class="bi bi-stars"></i> KI
                                        </span>
                                    }
                                </td>
                                <td>@a.AntragTyp</td>
                                <td><span class="mc-badge @StatusBadgeClass(a.Status)">@a.Status</span></td>
                                <td>@a.EingereichtVon</td>
                                <td>@(a.Leasinggesellschaft ?? "–")</td>
                                <td>@(a.SachbearbeiterMB ?? "–")</td>
                                <td style="text-align:right;" class="text-currency">@a.Obligo.ToString("N2") €</td>
                                <td style="color:var(--mc-text-muted); font-size:0.82rem;">@a.ErstelltAm.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@a.Id" class="btn-mc-ghost"
                                       style="font-size:0.78rem; padding:0.3rem 0.7rem;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string StatusBadgeClass(AntragStatus status) => status switch
    {
        AntragStatus.Entwurf                => "badge-secondary",
        AntragStatus.Eingereicht            => "badge-warning",
        AntragStatus.InPruefung             => "badge-primary",
        AntragStatus.BeiMitarbeiter         => "badge-primary",
        AntragStatus.BeiLeasinggesellschaft => "badge-primary",
        AntragStatus.ZweiteVoteErforderlich => "badge-warning",
        AntragStatus.Genehmigt              => "badge-success",
        AntragStatus.Abgelehnt              => "badge-danger",
        AntragStatus.Archiviert             => "badge-secondary",
        AntragStatus.KiEingereicht          => "badge-warning",
        _                                   => "badge-secondary"
    };
}

<!-- ── KI-Upload Modal ──────────────────────────────────────────────────────── -->
<div class="modal fade" id="kiUploadModalEl" tabindex="-1" aria-labelledby="kiUploadLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px; border:1px solid var(--mc-border); background:var(--mc-surface);">
            <!-- Header -->
            <div class="modal-header" style="background:linear-gradient(135deg,#16213e 0%,#1a2a50 100%); border-radius:14px 14px 0 0; border:none;">
                <h5 class="modal-title" id="kiUploadLabel" style="color:#fff; font-size:.95rem; display:flex; align-items:center; gap:.5rem;">
                    <i class="bi bi-stars" style="color:#c9a84c;"></i> Neuer Antrag mit KI
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <!-- Body: Schritt 1 – Upload -->
            <div class="modal-body p-4" id="kiSchritt1">
                <p style="font-size:.85rem; color:var(--mc-text-muted); margin-bottom:1rem;">
                    Laden Sie das Antragsdokument als PDF hoch. Die KI extrahiert automatisch die relevanten Felder.
                </p>
                <div id="kiDropzone"
                     style="border:2px dashed var(--mc-border); border-radius:10px; padding:2rem 1rem;
                            text-align:center; cursor:pointer; transition:border-color .2s;"
                     onclick="document.getElementById('kiPdfInput').click()"
                     ondragover="event.preventDefault(); this.style.borderColor='var(--mc-gold)'"
                     ondragleave="this.style.borderColor='var(--mc-border)'"
                     ondrop="kiHandleDrop(event)">
                    <i class="bi bi-file-earmark-pdf" style="font-size:2.5rem; color:var(--mc-text-muted); opacity:.5;"></i>
                    <p style="margin:.5rem 0 0; font-size:.85rem; color:var(--mc-text-muted);">
                        PDF hier ablegen oder <span style="color:var(--mc-gold); font-weight:600;">klicken</span> zum Auswählen
                    </p>
                    <p id="kiDateiname" style="font-size:.78rem; color:var(--mc-text-muted); margin:.4rem 0 0;"></p>
                </div>
                <input type="file" id="kiPdfInput" accept=".pdf,application/pdf" style="display:none" onchange="kiDateiGewaehlt(this)" />
                <div id="kiUploadFehler" class="alert alert-danger mt-3 mb-0 small" style="display:none;"></div>
            </div>
            <!-- Body: Schritt 2 – Analyse läuft -->
            <div class="modal-body p-4 text-center" id="kiSchritt2" style="display:none;">
                <div style="display:flex; flex-direction:column; align-items:center; gap:1rem; padding:1rem 0;">
                    <div class="spinner-border" style="color:var(--mc-gold); width:2.5rem; height:2.5rem;"></div>
                    <p style="font-size:.88rem; color:var(--mc-text-muted); margin:0;">
                        KI analysiert das Dokument…
                    </p>
                </div>
            </div>
            <!-- Body: Schritt 3 – Ergebnis -->
            <div class="modal-body p-4" id="kiSchritt3" style="display:none;">
                <div style="display:flex; align-items:center; gap:.6rem; margin-bottom:1rem;">
                    <i class="bi bi-check-circle-fill" style="color:var(--mc-success); font-size:1.3rem;"></i>
                    <span style="font-size:.9rem; font-weight:600; color:var(--mc-text);">Analyse abgeschlossen</span>
                    <span id="kiKonfidenzBadge" class="mc-badge ms-auto"></span>
                </div>
                <table style="width:100%; font-size:.83rem; border-collapse:collapse;">
                    <tbody id="kiErgebnisTabelle"></tbody>
                </table>
                <p style="font-size:.76rem; color:var(--mc-text-muted); margin-top:.75rem; margin-bottom:0;">
                    <i class="bi bi-info-circle me-1"></i>
                    Bitte prüfen und ergänzen Sie die Felder im nächsten Schritt.
                </p>
            </div>
            <!-- Footer -->
            <div class="modal-footer" style="border-top:1px solid var(--mc-border); padding:.75rem 1.25rem;">
                <button type="button" class="btn-mc-ghost" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn-mc-primary" id="kiAnalysierenBtn" onclick="kiAnalysieren()" disabled>
                    <i class="bi bi-stars me-1"></i> Analysieren
                </button>
                <button type="button" id="kiWeiterBtn" class="btn-mc-primary" style="display:none;"
                        onclick="kiAntragEinreichen()">
                    <i class="bi bi-stars me-1"></i> Antrag einreichen
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const kiUploadModal = new bootstrap.Modal(document.getElementById('kiUploadModalEl'));
let kiGewaehleDatei = null;
let kiErgebnis     = null;

function kiHandleDrop(e) {
    e.preventDefault();
    document.getElementById('kiDropzone').style.borderColor = 'var(--mc-border)';
    const f = e.dataTransfer.files[0];
    if (f) kiSetDatei(f);
}

function kiDateiGewaehlt(input) {
    if (input.files[0]) kiSetDatei(input.files[0]);
}

function kiSetDatei(f) {
    if (!f.name.toLowerCase().endsWith('.pdf')) {
        document.getElementById('kiUploadFehler').textContent = 'Nur PDF-Dateien sind erlaubt.';
        document.getElementById('kiUploadFehler').style.display = '';
        return;
    }
    kiGewaehleDatei = f;
    document.getElementById('kiDateiname').textContent = f.name + ' (' + (f.size / 1024).toFixed(0) + ' KB)';
    document.getElementById('kiDropzone').style.borderColor = 'var(--mc-gold)';
    document.getElementById('kiUploadFehler').style.display = 'none';
    document.getElementById('kiAnalysierenBtn').disabled = false;
}

async function kiAnalysieren() {
    if (!kiGewaehleDatei) return;

    document.getElementById('kiSchritt1').style.display = 'none';
    document.getElementById('kiSchritt2').style.display = '';
    document.getElementById('kiAnalysierenBtn').style.display = 'none';
    document.querySelector('#kiUploadModalEl .modal-footer .btn-mc-ghost').style.display = 'none';

    const fd = new FormData();
    fd.append('pdf', kiGewaehleDatei);

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    try {
        const resp = await fetch('/Antraege/PdfAnalysieren', {
            method: 'POST',
            headers: token ? { 'RequestVerificationToken': token } : {},
            body: fd
        });
        const data = await resp.json();

        if (data.error) {
            kiZeigeSchritt1Fehler(data.error);
            return;
        }

        kiErgebnis = data;

        document.getElementById('kiSchritt2').style.display = 'none';
        document.getElementById('kiSchritt3').style.display = '';

        const konfBadge = document.getElementById('kiKonfidenzBadge');
        const konfMap   = { hoch: ['badge-success','Hohe Konfidenz'], mittel: ['badge-warning','Mittlere Konfidenz'], niedrig: ['badge-secondary','Niedrige Konfidenz'] };
        const [cls, lbl] = konfMap[data.konfidenz] || konfMap.niedrig;
        konfBadge.className = 'mc-badge ms-auto ' + cls;
        konfBadge.textContent = lbl;

        const tbody = document.getElementById('kiErgebnisTabelle');
        const rows = [
            ['Antragstyp',         data.antragTypName  || '–'],
            ['Obligo',             data.obligo != null ? data.obligo.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €' : '–'],
            ['Abrechnungsart',     data.abrechnungsart || '–'],
            ['Leasinggesellschaft',data.leasinggesellschaftName || '–'],
        ];
        tbody.innerHTML = rows.map(([k,v]) => `
            <tr>
                <td style="padding:.35rem .5rem; color:var(--mc-text-muted); white-space:nowrap;">${k}</td>
                <td style="padding:.35rem .5rem; color:var(--mc-text); font-weight:500;">${v}</td>
            </tr>`).join('');

        document.getElementById('kiWeiterBtn').style.display = '';
        document.querySelector('#kiUploadModalEl .modal-footer .btn-mc-ghost').style.display = '';

    } catch (e) {
        kiZeigeSchritt1Fehler('Verbindungsfehler: ' + e.message);
    }
}

async function kiAntragEinreichen() {
    if (!kiErgebnis) return;
    const btn = document.getElementById('kiWeiterBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Wird eingereicht…';

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const fd = new FormData();
    if (token) fd.append('__RequestVerificationToken', token);
    if (kiErgebnis.antragTyp != null)          fd.append('antragTyp',            kiErgebnis.antragTyp);
    if (kiErgebnis.obligo != null)             fd.append('obligo',               kiErgebnis.obligo);
    if (kiErgebnis.abrechnungsart)             fd.append('abrechnungsart',        kiErgebnis.abrechnungsart);
    if (kiErgebnis.leasinggesellschaftId)      fd.append('leasinggesellschaftId', kiErgebnis.leasinggesellschaftId);
    if (kiErgebnis.tempToken)                  fd.append('tempToken',             kiErgebnis.tempToken);
    if (kiErgebnis.dateiname)                  fd.append('dateiname',             kiErgebnis.dateiname);

    try {
        const resp = await fetch('/Antraege/KiAntragErstellen', { method: 'POST', body: fd });
        const data = await resp.json();
        if (data.error) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-stars me-1"></i> Antrag einreichen';
            document.getElementById('kiUploadFehler').textContent = data.error;
            document.getElementById('kiUploadFehler').style.display = '';
            return;
        }
        kiUploadModal.hide();
        window.location.href = '/Antraege/Details/' + data.antragId;
    } catch (e) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars me-1"></i> Antrag einreichen';
        document.getElementById('kiUploadFehler').textContent = 'Fehler beim Einreichen: ' + e.message;
        document.getElementById('kiUploadFehler').style.display = '';
    }
}

function kiZeigeSchritt1Fehler(msg) {
    document.getElementById('kiSchritt2').style.display = 'none';
    document.getElementById('kiSchritt1').style.display = '';
    document.getElementById('kiAnalysierenBtn').style.display = '';
    document.getElementById('kiAnalysierenBtn').disabled = false;
    document.querySelector('#kiUploadModalEl .modal-footer .btn-mc-ghost').style.display = '';
    document.getElementById('kiUploadFehler').textContent = msg;
    document.getElementById('kiUploadFehler').style.display = '';
}

document.getElementById('kiUploadModalEl').addEventListener('hidden.bs.modal', function () {
    kiGewaehleDatei = null;
    kiErgebnis      = null;
    document.getElementById('kiSchritt1').style.display = '';
    document.getElementById('kiSchritt2').style.display = 'none';
    document.getElementById('kiSchritt3').style.display = 'none';
    document.getElementById('kiAnalysierenBtn').style.display = '';
    document.getElementById('kiAnalysierenBtn').disabled = true;
    document.getElementById('kiWeiterBtn').style.display = 'none';
    document.getElementById('kiWeiterBtn').disabled = false;
    document.getElementById('kiWeiterBtn').innerHTML = '<i class="bi bi-stars me-1"></i> Antrag einreichen';
    document.getElementById('kiDateiname').textContent = '';
    document.getElementById('kiDropzone').style.borderColor = 'var(--mc-border)';
    document.getElementById('kiUploadFehler').style.display = 'none';
    document.getElementById('kiPdfInput').value = '';
});
</script>
}
