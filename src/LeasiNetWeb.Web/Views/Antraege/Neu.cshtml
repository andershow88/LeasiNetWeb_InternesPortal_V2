@model LeasiNetWeb.Web.ViewModels.AntragErstellenViewModel
@{
    ViewData["Title"] = "Neuer Antrag";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a asp-action="Index">Anträge</a></li>
            <li class="breadcrumb-item active">Neuer Antrag</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-plus-circle me-2"></i>Neuer Leasingantrag</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Neu" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="AntragTyp" class="form-label fw-semibold"></label>
                        <select asp-for="AntragTyp" asp-items="ViewBag.AntragTypen" class="form-select">
                            <option value="">Bitte wählen…</option>
                        </select>
                        <span asp-validation-for="AntragTyp" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LeasinggesellschaftId" class="form-label fw-semibold"></label>
                        <select asp-for="LeasinggesellschaftId" asp-items="ViewBag.Leasinggesellschaften" class="form-select">
                            <option value="">– keine Auswahl –</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Obligo" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Obligo" class="form-control" type="number" step="0.01" min="0.01" />
                            <span class="input-group-text">EUR</span>
                        </div>
                        <span asp-validation-for="Obligo" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Abrechnungsart" class="form-label fw-semibold"></label>
                        <input asp-for="Abrechnungsart" class="form-control" placeholder="z. B. Monatlich, Vierteljährlich…" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Als Entwurf speichern
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
