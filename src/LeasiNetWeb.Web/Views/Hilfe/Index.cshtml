@model IEnumerable<LeasiNetWeb.Domain.Entities.HilfeText>
@{
    ViewData["Title"] = "Hilfe & Informationen";
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title">
            <i class="bi bi-question-circle me-2" style="color:var(--mc-gold);font-size:1.3rem;"></i>
            Hilfe & Informationen
        </h1>
        <p class="mc-page-subtitle">Unterstützung für das LeasiNetWeb Interne Portal</p>
    </div>
</div>

<div class="row g-3">

    <!-- Ansprechpartner -->
    <div class="col-lg-6">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-telephone-fill"></i> Ihr Ansprechpartner</h2>
            </div>
            <div class="mc-card-body">
                <div class="mc-contact-card">
                    <div class="mc-contact-icon"><i class="bi bi-person-lines-fill"></i></div>
                    <div>
                        <div class="fw-bold" style="color:var(--mc-navy);">Merkur Privatbank KGaA</div>
                        <div class="text-muted small">Abteilung Leasing / Sachbearbeitung</div>
                        <div class="mt-2">
                            <div class="mb-1"><i class="bi bi-telephone text-primary me-2"></i>+49 (0)89 455 890-0</div>
                            <div class="mb-1"><i class="bi bi-envelope text-primary me-2"></i>leasing@merkur-privatbank.de</div>
                            <div><i class="bi bi-clock text-primary me-2"></i>Mo–Fr 8:00–17:00 Uhr</div>
                        </div>
                    </div>
                </div>

                <div class="mc-contact-card">
                    <div class="mc-contact-icon" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-headset"></i></div>
                    <div>
                        <div class="fw-bold" style="color:var(--mc-navy);">Technischer Support</div>
                        <div class="text-muted small">Bei Fragen zur Portalnutzung</div>
                        <div class="mt-2">
                            <div class="mb-1"><i class="bi bi-envelope text-primary me-2"></i>portal-support@merkur-privatbank.de</div>
                            <div><i class="bi bi-clock text-primary me-2"></i>Mo–Fr 8:00–18:00 Uhr</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FAQ -->
    <div class="col-lg-6">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-patch-question-fill"></i> Häufige Fragen</h2>
            </div>
            <div class="mc-card-body">
                <div class="accordion accordion-flush" id="faqAccordion">
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#faq1"
                                    style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                Was bedeuten die verschiedenen Antragsstatus?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse">
                            <div class="accordion-body px-0 pt-0 pb-2 text-muted" style="font-size:0.82rem;">
                                <div class="d-flex flex-column gap-1 mt-1">
                                    <div><span class="mc-badge badge-secondary me-2">Entwurf</span> Antrag noch in Bearbeitung, noch nicht eingereicht</div>
                                    <div><span class="mc-badge badge-warning me-2">Eingereicht</span> Antrag wurde eingereicht, wartet auf Prüfung</div>
                                    <div><span class="mc-badge badge-primary me-2">In Prüfung</span> Sachbearbeiter prüft den Antrag aktiv</div>
                                    <div><span class="mc-badge badge-warning me-2">2. Vote</span> Zweites Votum durch einen Genehmiger erforderlich</div>
                                    <div><span class="mc-badge badge-success me-2">Genehmigt</span> Antrag wurde genehmigt</div>
                                    <div><span class="mc-badge badge-danger me-2">Abgelehnt</span> Antrag wurde abgelehnt</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#faq2"
                                    style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                Wer kann Anträge genehmigen oder ablehnen?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse">
                            <div class="accordion-body px-0 pt-0 pb-2 text-muted" style="font-size:0.82rem;">
                                Nur Benutzer mit der Rolle <strong>Genehmiger</strong> oder <strong>Administrator</strong>
                                können Anträge genehmigen oder ablehnen. Sachbearbeiter können Anträge prüfen
                                und zur Genehmigung weiterleiten. Wenn ein 2. Vote erforderlich ist,
                                muss ein zweiter Genehmiger zustimmen.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#faq3"
                                    style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                Welche Dokumente kann ich hochladen?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse">
                            <div class="accordion-body px-0 pt-0 pb-2 text-muted" style="font-size:0.82rem;">
                                Sie können PDF, Word, Excel sowie gängige Bilddateien hochladen.
                                Die maximale Dateigröße beträgt 50 MB. Bitte stellen Sie sicher,
                                dass Sie zur Weitergabe der Dokumente berechtigt sind.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-bottom">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#faq4"
                                    style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                Wie funktioniert die interne Prüfung?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse">
                            <div class="accordion-body px-0 pt-0 pb-2 text-muted" style="font-size:0.82rem;">
                                Nach der Genehmigung eines Antrags wird automatisch eine interne Prüfung
                                angelegt. Der zugewiesene interne Prüfer arbeitet eine Checkliste ab
                                und dokumentiert die Ergebnisse im Prüfungsprotokoll. Erst nach Abschluss
                                aller Prüfschritte gilt die Prüfung als abgeschlossen.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed py-2 px-0" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#faq5"
                                    style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                Wann wird ein Antrag archiviert?
                            </button>
                        </h2>
                        <div id="faq5" class="accordion-collapse collapse">
                            <div class="accordion-body px-0 pt-0 pb-2 text-muted" style="font-size:0.82rem;">
                                Anträge können manuell durch einen Sachbearbeiter oder Administrator archiviert werden,
                                sobald sie vollständig abgeschlossen sind. Archivierte Anträge sind
                                weiterhin über den Menüpunkt <strong>Archiv</strong> einsehbar,
                                erscheinen aber nicht mehr in der regulären Antragsübersicht.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Portalinformationen -->
    <div class="col-12">
        <div class="mc-card">
            <div class="mc-card-header">
                <h2 class="mc-card-title"><i class="bi bi-info-circle-fill"></i> Über das Portal</h2>
            </div>
            <div class="mc-card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="mc-info-box mc-info-box-default">
                            <div class="mc-info-box-title">
                                <i class="bi bi-rocket-takeoff text-primary me-1"></i> LeasiNetWeb – Version 2.0
                            </div>
                            <div class="mc-info-box-body">
                                Internes Leasingportal der Merkur Privatbank KGaA zur Verwaltung
                                von Leasinganträgen, Genehmigungsprozessen und internen Prüfungen.
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mc-info-box mc-info-box-success">
                            <div class="mc-info-box-title">
                                <i class="bi bi-shield-check me-1"></i> Datenschutz
                            </div>
                            <div class="mc-info-box-body">
                                Alle Daten werden ausschließlich auf Servern der Merkur Privatbank KGaA
                                innerhalb Deutschlands verarbeitet. Zugang nur für autorisierte Mitarbeiter.
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mc-info-box mc-info-box-warning">
                            <div class="mc-info-box-title">
                                <i class="bi bi-exclamation-triangle me-1"></i> Demo-Umgebung
                            </div>
                            <div class="mc-info-box-body">
                                Diese Instanz enthält Demo-Daten zu Testzwecken.
                                Produktive Daten werden nach finaler Freigabe und Systemanbindung integriert.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.AnwenderdokumentationHtml != null)
    {
        <!-- Anwenderdokumentation -->
        <div class="col-12">
            <div class="mc-card">
                <div class="mc-card-header">
                    <h2 class="mc-card-title"><i class="bi bi-book-fill"></i> Weitere Informationen</h2>
                </div>
                <div class="mc-card-body">
                    <div class="accordion accordion-flush" id="dokuAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-2 px-0" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#dokuInhalt"
                                        style="font-size:0.85rem; font-weight:600; background:none; color:var(--mc-text);">
                                    <i class="bi bi-file-text me-2" style="color:var(--mc-gold);"></i> Anwenderdokumentation
                                </button>
                            </h2>
                            <div id="dokuInhalt" class="accordion-collapse collapse">
                                <div class="accordion-body px-0 pt-3 pb-2">
                                    <!-- Suchleiste -->
                                    <div style="position:sticky; top:0; z-index:10; background:var(--mc-bg-card); padding-bottom:0.75rem; margin-bottom:0.75rem; border-bottom:1px solid var(--mc-border);">
                                        <div style="display:flex; align-items:center; gap:0.5rem;
                                                    border:1.5px solid var(--mc-border); border-radius:8px;
                                                    padding:0.4rem 0.75rem; background:var(--mc-bg);"
                                             id="dokuSuchWrapper"
                                             onfocusin="this.style.borderColor='var(--mc-gold)'"
                                             onfocusout="this.style.borderColor='var(--mc-border)'">
                                            <i class="bi bi-search" style="color:var(--mc-text-muted); font-size:0.85rem; flex-shrink:0;"></i>
                                            <input id="dokuSuche" type="search" placeholder="Dokumentation durchsuchen…"
                                                   style="flex:1; border:none; background:transparent; color:var(--mc-text);
                                                          font-size:0.85rem; outline:none; font-family:inherit;" />
                                            <span id="dokuTreffer" style="font-size:0.75rem; color:var(--mc-text-muted); flex-shrink:0; display:none;"></span>
                                        </div>
                                    </div>
                                    <!-- Dokumentationsinhalt -->
                                    <div id="dokuInhaltText" class="mc-doku-body">
                                        @Html.Raw(ViewBag.AnwenderdokumentationHtml)
                                    </div>
                                    <div id="dokuKeineTreffer" style="display:none; text-align:center; padding:2rem 0; color:var(--mc-text-muted);">
                                        <i class="bi bi-search" style="font-size:1.5rem; opacity:0.3;"></i>
                                        <p class="mt-2 mb-0 small">Kein Ergebnis gefunden.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@section Scripts {
<style>
/* ── Anwenderdokumentation Inhalt ── */
.mc-doku-body { font-size: 0.86rem; color: var(--mc-text); line-height: 1.7; }
.mc-doku-body h1 { font-size: 1.3rem; font-weight: 700; color: var(--mc-navy); margin: 1.5rem 0 0.5rem; }
.mc-doku-body h2 { font-size: 1.1rem; font-weight: 700; color: var(--mc-navy); margin: 1.4rem 0 0.4rem; padding-bottom: 0.3rem; border-bottom: 1px solid var(--mc-border); }
.mc-doku-body h3 { font-size: 0.95rem; font-weight: 700; color: var(--mc-text); margin: 1.1rem 0 0.3rem; }
.mc-doku-body h4 { font-size: 0.88rem; font-weight: 600; color: var(--mc-text-muted); margin: 0.9rem 0 0.25rem; }
.mc-doku-body p  { margin: 0.4rem 0 0.75rem; color: var(--mc-text-muted); }
.mc-doku-body ul, .mc-doku-body ol { margin: 0.3rem 0 0.75rem 1.3rem; color: var(--mc-text-muted); }
.mc-doku-body li { margin-bottom: 0.25rem; }
.mc-doku-body code { font-size: 0.8rem; background: var(--mc-border); color: var(--mc-text); padding: 0.1em 0.4em; border-radius: 4px; }
.mc-doku-body pre { background: var(--mc-bg); border: 1px solid var(--mc-border); border-radius: 6px; padding: 0.75rem 1rem; overflow-x: auto; margin: 0.5rem 0 1rem; }
.mc-doku-body pre code { background: none; padding: 0; font-size: 0.78rem; }
.mc-doku-body table { width: 100%; border-collapse: collapse; margin: 0.5rem 0 1rem; font-size: 0.82rem; }
.mc-doku-body table th { background: var(--mc-bg); color: var(--mc-text); font-weight: 600; padding: 0.45rem 0.7rem; border: 1px solid var(--mc-border); text-align: left; }
.mc-doku-body table td { padding: 0.4rem 0.7rem; border: 1px solid var(--mc-border); color: var(--mc-text-muted); }
.mc-doku-body table tr:nth-child(even) td { background: var(--mc-bg); }
.mc-doku-body blockquote { border-left: 3px solid var(--mc-gold); margin: 0.5rem 0 0.75rem; padding: 0.4rem 0.9rem; background: var(--mc-bg); border-radius: 0 4px 4px 0; color: var(--mc-text-muted); font-style: italic; }
.mc-doku-body hr { border: none; border-top: 1px solid var(--mc-border); margin: 1.2rem 0; }
.mc-doku-body a { color: var(--mc-primary); text-decoration: none; }
.mc-doku-body a:hover { text-decoration: underline; }
/* Suchtreffern hervorheben */
.mc-doku-body mark { background: #fde68a; color: #1a1a1a; border-radius: 2px; padding: 0 2px; }
[data-theme="dark"] .mc-doku-body mark { background: #6b4a00; color: #fde68a; }
</style>

<script>
(function () {
    const suchfeld  = document.getElementById('dokuSuche');
    const inhalt    = document.getElementById('dokuInhaltText');
    const trefferEl = document.getElementById('dokuTreffer');
    const keinEl    = document.getElementById('dokuKeineTreffer');
    if (!suchfeld || !inhalt) return;

    // Originalinhalt merken (einmalig)
    const originalHtml = inhalt.innerHTML;

    suchfeld.addEventListener('input', function () {
        const term = this.value.trim();

        if (!term) {
            inhalt.innerHTML = originalHtml;
            inhalt.style.display = '';
            keinEl.style.display = 'none';
            trefferEl.style.display = 'none';
            return;
        }

        // Originalinhalt zurücksetzen, dann neu hervorheben
        inhalt.innerHTML = originalHtml;

        const regex = new RegExp(escapeRegex(term), 'gi');
        let count = 0;
        highlightInNode(inhalt, regex, function () { count++; });

        trefferEl.textContent = count + ' Treffer';
        trefferEl.style.display = count > 0 ? '' : 'none';
        inhalt.style.display = count > 0 ? '' : 'none';
        keinEl.style.display = count === 0 ? '' : 'none';

        // Zum ersten Treffer scrollen
        if (count > 0) {
            const first = inhalt.querySelector('mark');
            if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });

    function highlightInNode(node, regex, onMatch) {
        if (node.nodeType === Node.TEXT_NODE) {
            const text = node.textContent;
            if (regex.test(text)) {
                regex.lastIndex = 0;
                const frag = document.createDocumentFragment();
                let last = 0, m;
                regex.lastIndex = 0;
                while ((m = regex.exec(text)) !== null) {
                    if (m.index > last)
                        frag.appendChild(document.createTextNode(text.slice(last, m.index)));
                    const mark = document.createElement('mark');
                    mark.textContent = m[0];
                    frag.appendChild(mark);
                    onMatch();
                    last = regex.lastIndex;
                }
                if (last < text.length)
                    frag.appendChild(document.createTextNode(text.slice(last)));
                node.parentNode.replaceChild(frag, node);
            }
        } else if (node.nodeType === Node.ELEMENT_NODE &&
                   !['SCRIPT','STYLE','INPUT','TEXTAREA'].includes(node.tagName)) {
            // Kinder von hinten nach vorne durchlaufen (wegen DOM-Modifikation)
            const children = Array.from(node.childNodes);
            children.forEach(child => highlightInNode(child, regex, onMatch));
        }
    }

    function escapeRegex(s) {
        return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
})();
</script>
}
