@using LeasiNetWeb.Application.DTOs
@model IEnumerable<InternePruefungListeDto>
@{
    ViewData["Title"] = "Interne Prüfungen";
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-shield-check me-2"></i>Interne Prüfungen</h1>
    </div>
</div>

<div class="mc-card">
    <div style="padding:0;">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:var(--mc-text-muted);">
                <i class="bi bi-shield-check" style="font-size:2.5rem; opacity:0.3;"></i>
                <p class="mt-3 mb-0">Keine offenen Prüfungen vorhanden.</p>
            </div>
        }
        else
        {
            <table class="mc-table">
                <thead>
                    <tr>
                        <th>Prüfung-Nr.</th>
                        <th>Antrag-Nr.</th>
                        <th>Hauptprüfer</th>
                        <th>Workflow</th>
                        <th>Checkliste</th>
                        <th>Status</th>
                        <th>Abgeschlossen</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        var pctPflichten = p.AnzahlPflichten > 0 ? (p.AnzahlErfuellt * 100 / p.AnzahlPflichten) : 0;
                        var pctSchritte  = p.AnzahlSchritte > 0  ? (p.AnzahlSchritteAbgeschlossen * 100 / p.AnzahlSchritte) : 100;
                        var bereit = pctPflichten == 100 && pctSchritte == 100;
                        <tr>
                            <td style="font-size:0.82rem;">
                                @if (!string.IsNullOrEmpty(p.PruefungNummer))
                                { <code style="font-size:.8rem;">@p.PruefungNummer</code> }
                                else
                                { <span style="color:var(--mc-text-muted);">–</span> }
                            </td>
                            <td><code style="font-size:.8rem;">@p.AntragNummer</code></td>
                            <td style="font-size:0.85rem;">@p.PrueferMB</td>
                            <td style="min-width:120px;">
                                @if (p.AnzahlSchritte > 0)
                                {
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <div style="flex:1; background:var(--mc-border); border-radius:4px; height:5px; overflow:hidden;">
                                            <div style="width:@pctSchritte%; background:var(--mc-navy); height:100%; transition:width .3s;"></div>
                                        </div>
                                        <span style="font-size:0.75rem; color:var(--mc-text-muted); white-space:nowrap;">@p.AnzahlSchritteAbgeschlossen/@p.AnzahlSchritte</span>
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--mc-text-muted); font-size:0.78rem;">–</span>
                                }
                            </td>
                            <td style="min-width:120px;">
                                <div style="display:flex; align-items:center; gap:0.5rem;">
                                    <div style="flex:1; background:var(--mc-border); border-radius:4px; height:5px; overflow:hidden;">
                                        <div style="width:@pctPflichten%; background:var(--mc-primary); height:100%; transition:width .3s;"></div>
                                    </div>
                                    <span style="font-size:0.75rem; color:var(--mc-text-muted); white-space:nowrap;">@p.AnzahlErfuellt/@p.AnzahlPflichten</span>
                                </div>
                            </td>
                            <td>
                                @if (p.Abgeschlossen)
                                {
                                    <span class="mc-badge badge-success">Abgeschlossen</span>
                                }
                                else if (bereit)
                                {
                                    <span class="mc-badge badge-warning">Bereit zum Abschluss</span>
                                }
                                else
                                {
                                    <span class="mc-badge badge-primary">In Bearbeitung</span>
                                }
                            </td>
                            <td style="color:var(--mc-text-muted); font-size:0.82rem;">
                                @(p.AbgeschlossenAm.HasValue ? p.AbgeschlossenAm.Value.ToString("dd.MM.yyyy") : "–")
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-antragId="@p.LeasingantragId"
                                   class="btn-mc-ghost" style="font-size:0.8rem; padding:0.25rem 0.6rem;">
                                    <i class="bi bi-arrow-right"></i> Öffnen
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
